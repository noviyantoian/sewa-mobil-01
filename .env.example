# ── Tenant (per-client deploy) ───────────────────────────────────────────────
# This instance is pinned to ONE tenant (instance-per-tenant model). Its DB holds
# exactly this tenant. Set the slug seeded in `tenants`.
TENANT_SLUG=demo

# ── Database (NATIVE Postgres on the VPS — target deploy model) ───────────────
# Per client: a dedicated database owned by the `folkadrive` role.
#   1) once per server (superuser):  psql -f scripts/db/bootstrap-roles.sql
#   2) per client (superuser):       CREATE DATABASE klien_a OWNER folkadrive;
#   3) apply schema:                  node --env-file=.env scripts/migrate.mjs
# DATABASE_URL="postgresql://folkadrive:[STRONG-PASSWORD]@localhost:5432/klien_a"
# APP_DB_ROLE=folkadrive   # the role above; member of app_user (SET LOCAL ROLE)

# ── Database (Supabase Postgres — legacy, being replaced) ────────────────────
# Project: sewa-mobil · ref nuraugjawzlrlflaqkwk · region ap-southeast-1
# Copy this file to `.env` (gitignored) and fill [YOUR-PASSWORD] from:
#   Supabase Dashboard → Project Settings → Database → Connection string
#
# RUNTIME (app): use the Transaction pooler — IPv4, works on serverless.
# Copy the EXACT pooler host shown in the dashboard (region prefix differs
# per project, e.g. aws-0-… or aws-1-…). Keep `?prepare=false` via the driver.
DATABASE_URL="postgresql://postgres.nuraugjawzlrlflaqkwk:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres"
#
# MIGRATIONS / studio (drizzle-kit): direct connection (session-level, IPv6).
# If your network is IPv4-only, use the Session pooler (port 5432) instead.
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.nuraugjawzlrlflaqkwk.supabase.co:5432/postgres"

# ── Supabase public API (auth + storage) ────────────────────────────────────
# These are PUBLIC (shipped to the browser) — safe to commit. No quotes.
NEXT_PUBLIC_SUPABASE_URL=https://nuraugjawzlrlflaqkwk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_pHpWQZtcxinlpuY7PDEu0w_xzdfLaNk

# ── Admin auth (better-auth) ─────────────────────────────────────────────────
# Session signing secret — REQUIRED. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin of this instance (used by better-auth). Leave empty in dev to
# resolve from the request; set in production, e.g. https://rental.klien.com
BETTER_AUTH_URL=
# Create/reset the admin login (operator-supplied password, min 8 chars):
#   ADMIN_EMAIL=owner@klien.com ADMIN_PASSWORD='...' pnpm create-admin

# ── Admin allow-list (server-only, NOT public) ───────────────────────────────
# Comma-separated emails allowed into /admin. A Supabase session alone is NOT
# enough — the user's email must be listed here. Create the matching user in
# Supabase Dashboard → Authentication → Users (Auto Confirm).
ADMIN_EMAILS=admin@folkadrive.local

# ── Foto storage (opsional) ──────────────────────────────────────────────────
# Kosongkan = pakai Supabase Storage (bucket 'assets', sudah jalan).
# Isi semua 5 = otomatis pindah ke Cloudflare R2 (zero egress). Server-only.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=folkadrive-assets
# R2_PUBLIC_BASE_URL=https://cdn.folkadrive.com

# ── Public asset CDN (R2 custom domain) ──────────────────────────────────────
# Client-safe (NEXT_PUBLIC). Prefixes static marketing images (lib/asset.ts).
# Leave empty to serve from /public locally.
NEXT_PUBLIC_ASSET_BASE_URL=https://cdn.folkadrive.com

# ── Public site origin (SEO / OG) ────────────────────────────────────────────
# Domain LIVE asli (build-time). Dipakai metadataBase, og:url, canonical.
NEXT_PUBLIC_SITE_URL=https://folkadrive.com
